{
    "extends": [
        "config:recommended"
    ],
    "terraform": {
        "enabled": true
    },
    "ansible": {
        "enabled": true
    },
    "flux": {
        "enabled": true
    },
    "packageRules": [
        {
            "description": "Automatically merge minor and patch-level updates",
            "matchUpdateTypes": ["minor", "patch", "digest"],
            "automerge": true,
            "automergeType": "branch"
        }
    ]
}